NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/booking
CORS_ORIGIN=http://localhost:3000

# JWT — en az 32 karakter (örnek; üretimde güçlü bir sır kullanın)
JWT_SECRET=change-me-use-at-least-32-chars-long-secret
JWT_EXPIRES_IN=7d
AUTH_COOKIE_NAME=booking_token

# Atölye/danışman profil UUID — DB’deki profiles.id ile aynı olmalı (FK varsa)
BOOKING_PROFILE_ID=11111111-1111-1111-1111-111111111111
